<view class="page surface"><view wx:if="{{loading}}" class="loading">正在加载订单...</view><view wx:elif="{{!items.length}}" class="empty">暂无采购订单</view><view wx:for="{{items}}" wx:key="id" class="order-row" data-id="{{item.id}}" bindtap="detail"><view class="between"><text class="order-no">{{item.orderNo}}</text><order-status status="{{item.status}}" /></view><view class="meta">{{item.createdAt}} · {{item.items.length}} 件商品</view><view class="between amount"><text class="muted">订单金额</text><text class="price">¥{{item.totalAmount}}</text></view></view></view>
