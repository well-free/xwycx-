<view class="bind-page">
  <view class="brand">绑定手机号</view>
  <view class="intro">用于订单通知、配送联系与售后服务</view>
  <view class="form">
    <input class="input" type="number" maxlength="11" placeholder="手机号" value="{{phone}}" bindinput="phoneInput" />
    <view class="code-row">
      <input class="input code-input" type="number" maxlength="6" placeholder="验证码" value="{{code}}" bindinput="codeInput" />
      <button class="secondary" loading="{{sending}}" disabled="{{sending || binding}}" bindtap="sendCode">发送验证码</button>
    </view>
  </view>
  <view wx:if="{{error}}" class="error">{{error}}</view>
  <button class="primary submit" loading="{{binding}}" disabled="{{binding || sending}}" bindtap="submit">确认绑定</button>
  <button class="text-button" disabled="{{binding}}" bindtap="skip">稍后绑定</button>
</view>
