<view class="page detail-page" wx:if="{{item}}">
  <view class="media-panel"><image wx:if="{{item.mainImage}}" class="hero-image" src="{{item.mainImage}}" mode="aspectFit" /><view wx:else class="hero-image fallback">{{item.name}}</view><text class="stock-tag">{{item.stock > 0 ? '现货' : '缺货'}}</text></view>
  <view class="detail-panel">
    <view class="detail-name">{{item.name}}</view>
    <view class="meta">SKU {{item.sku}} · {{item.spec || '标准规格'}} · {{item.unit || '件'}}</view>
    <view class="between detail-price"><text class="price">¥{{item.price}}</text><text class="stock-copy">库存 {{item.stock}}</text></view>
  </view>
  <view class="detail-panel quantity-panel"><view class="row between"><text class="quantity-label">采购数量</text><view class="stepper"><text class="step-control" data-delta="-1" bindtap="step">−</text><text class="value">{{quantity}}</text><text class="step-control" data-delta="1" bindtap="step">＋</text></view></view></view>
  <view class="detail-panel description"><view class="section-title">商品说明</view><view class="muted">{{item.detailImages || '适用于门店、餐饮、办公等日常消耗场景。'}}</view></view>
  <view class="fixed-action"><button class="primary" disabled="{{item.stock <= 0}}" bindtap="add">{{item.stock > 0 ? '加入采购车' : '暂时缺货'}}</button></view>
</view>
