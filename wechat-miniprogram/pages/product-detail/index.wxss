.detail-page { padding-top: 0; }
.media-panel { position: relative; margin: 0 -28rpx; background: #edf2ef; }
.hero-image { display: flex; align-items: center; justify-content: center; width: 100%; height: 520rpx; }
.fallback { padding: 0 64rpx; color: #0b5038; font-size: 40rpx; font-weight: 700; text-align: center; }
.stock-tag { position: absolute; right: 28rpx; bottom: 24rpx; padding: 8rpx 14rpx; color: #0b5038; background: rgba(255, 255, 255, .9); border-radius: 6rpx; font-size: 22rpx; font-weight: 700; }
.detail-panel { margin: 20rpx -2rpx 0; padding: 28rpx; background: #fff; border: 1rpx solid #dfe7e2; border-radius: 12rpx; }
.detail-name { font-size: 38rpx; font-weight: 800; line-height: 1.4; }
.detail-price { margin-top: 28rpx; padding-top: 24rpx; border-top: 1rpx solid #e7ece9; }
.stock-copy { color: #147451; font-size: 24rpx; font-weight: 600; }
.quantity-panel { padding-top: 6rpx; padding-bottom: 6rpx; }
.quantity-label { font-weight: 600; }
.step-control { min-height: 58rpx; line-height: 58rpx; background: #f4f7f5; }
.description .section-title { padding-top: 0; }
.description .muted { line-height: 1.8; }
.fixed-action .primary { width: 100%; }
