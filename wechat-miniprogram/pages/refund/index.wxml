<view class="page surface"><view class="section-title">退款金额</view><input class="input" type="digit" value="{{amount}}" bindinput="amountInput" /><view class="section-title">退款原因</view><textarea class="textarea" maxlength="255" placeholder="请说明退款原因" value="{{reason}}" bindinput="reasonInput" /><button class="primary submit" loading="{{submitting}}" bindtap="submit">提交退款申请</button></view>
