<view class="page" wx:if="{{order}}">
  <view class="state-band"><order-status status="{{order.status}}" /><view class="meta">订单号 {{order.orderNo}}</view></view>
  <view class="section address"><view class="section-title">配送地址</view><view>{{order.shippingAddress.receiverName}} {{order.shippingAddress.receiverPhone}}</view><view class="muted">{{order.shippingAddress.province}}{{order.shippingAddress.city}}{{order.shippingAddress.district}}{{order.shippingAddress.detail}}</view></view>
  <view class="section items"><view class="section-title">采购明细</view><view wx:for="{{order.items}}" wx:key="id" class="row between"><view><view>{{item.productName}}</view><view class="meta">{{item.sku}} × {{item.quantity}}</view></view><text>¥{{item.subtotal}}</text></view></view>
  <view class="section summary"><view class="row between"><text>订单金额</text><text class="price">¥{{order.totalAmount}}</text></view><view class="row between"><text>订单备注</text><text class="muted">{{order.remark || '无'}}</text></view></view>
  <view class="actions"><button wx:if="{{order.status === 'PENDING_PAYMENT'}}" class="secondary" bindtap="cancel">取消订单</button><button wx:if="{{order.status === 'PENDING_PAYMENT'}}" class="primary" loading="{{paying}}" bindtap="pay">立即支付</button><button wx:if="{{order.status === 'PAID' || order.status === 'FULFILLING' || order.status === 'SHIPPED'}}" class="secondary" bindtap="refund">申请退款</button></view>
</view>
