<view class="page surface home-page">
  <view class="home-head">
    <view><view class="eyebrow">日常耗材采购</view><text class="brand">小卫优采</text></view>
    <button class="cart-link" bindtap="checkout" aria-label="打开采购车">采购车</button>
  </view>
  <view class="search-shell"><text class="search-icon">⌕</text><input class="search" placeholder="搜索商品或 SKU" value="{{keyword}}" bindinput="search" confirm-type="search" /></view>
  <view class="catalog-head"><view><view class="section-title">全部商品</view><view class="section-caption">门店、餐饮与办公常用耗材</view></view><text class="catalog-count">{{items.length}} 件</text></view>
  <view wx:if="{{loading}}" class="skeleton-list"><view wx:for="{{[1, 2, 3]}}" wx:key="*this" class="skeleton-row"><view class="skeleton-block skeleton-image"></view><view class="skeleton-content"><view class="skeleton-block skeleton-line"></view><view class="skeleton-block skeleton-line short"></view><view class="skeleton-block skeleton-line price-line"></view></view></view></view>
  <view wx:elif="{{error}}" class="empty"><view class="empty-mark">!</view><view class="empty-title">商品加载失败</view><view class="empty-copy">{{error}}</view><button class="secondary empty-action" bindtap="load">重新加载</button></view>
  <view wx:elif="{{!items.length}}" class="empty"><view class="empty-mark">⌕</view><view class="empty-title">没有找到相关商品</view><view class="empty-copy">换个商品名称或 SKU 试试</view></view>
  <product-card wx:for="{{items}}" wx:key="id" item="{{item}}" binddetail="detail" bindadd="add" />
</view>
