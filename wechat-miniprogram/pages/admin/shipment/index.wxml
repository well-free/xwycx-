<view class="page surface" wx:if="{{order}}"><view class="section-title">订单 {{order.orderNo}}</view><view class="meta">收货人 {{order.shippingAddress.receiverName}} · ¥{{order.totalAmount}}</view><input class="input field" placeholder="物流公司" data-field="carrier" value="{{carrier}}" bindinput="input" /><input class="input field" placeholder="物流单号" data-field="trackingNo" value="{{trackingNo}}" bindinput="input" /><button class="primary save" bindtap="ship">确认发货</button></view>
