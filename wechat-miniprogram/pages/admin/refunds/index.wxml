<view class="page surface"><view wx:if="{{!items.length}}" class="empty">暂无退款记录</view><view wx:for="{{items}}" wx:key="id" class="refund-row"><view class="between"><text class="no">退款单 {{item.id}}</text><text class="status-warn">{{item.status}}</text></view><view class="meta">支付单 {{item.paymentId}} · {{item.reason}}</view><view class="between foot"><text class="price">¥{{item.amount}}</text><button wx:if="{{item.status !== 'SUCCESS'}}" class="primary approve" data-id="{{item.id}}" bindtap="approve">审核退款</button></view></view></view>
