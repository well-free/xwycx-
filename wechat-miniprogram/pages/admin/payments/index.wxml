<view class="page surface"><view wx:if="{{!items.length}}" class="empty">暂无支付记录</view><view wx:for="{{items}}" wx:key="id" class="payment-row"><view class="between"><text class="no">支付单 {{item.id}}</text><text class="status">{{item.status}}</text></view><view class="meta">订单 {{item.orderId}} · {{item.channel}} · {{item.gatewayMode}}</view><view class="price amount">¥{{item.amount}}</view></view></view>
