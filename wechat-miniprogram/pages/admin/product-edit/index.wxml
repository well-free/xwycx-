<view class="page surface form-page"><input class="input" placeholder="SKU" data-field="sku" value="{{form.sku}}" bindinput="input" /><input class="input" placeholder="商品名称" data-field="name" value="{{form.name}}" bindinput="input" /><view class="pair"><input class="input" type="digit" placeholder="价格" data-field="price" value="{{form.price}}" bindinput="input" /><input class="input" type="number" placeholder="库存" data-field="stock" value="{{form.stock}}" bindinput="input" /></view><input class="input" placeholder="规格" data-field="spec" value="{{form.spec}}" bindinput="input" /><input class="input" placeholder="单位" data-field="unit" value="{{form.unit}}" bindinput="input" /><input class="input" placeholder="主图 URL" data-field="mainImage" value="{{form.mainImage}}" bindinput="input" /><view class="row between"><text>{{form.status === 'ON_SHELF' ? '上架' : '下架'}}</text><switch color="#147451" checked="{{form.status === 'ON_SHELF'}}" bindchange="status" /></view><button class="primary save" loading="{{saving}}" bindtap="save">保存商品</button></view>
