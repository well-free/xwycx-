<view class="page surface"><view class="between toolbar-line"><view class="section-title">商品</view><button class="primary small" bindtap="add">新增商品</button></view><view wx:for="{{items}}" wx:key="id" class="product-admin-row"><view class="between"><view><view class="name">{{item.name}}</view><view class="meta">{{item.sku}} · ¥{{item.price}} · 库存 {{item.stock}}</view></view><text class="status">{{item.status === 'ON_SHELF' ? '上架' : '下架'}}</text></view><view class="commands"><text data-index="{{index}}" bindtap="edit">编辑</text><text data-index="{{index}}" bindtap="stock">库存调整</text></view></view></view>
