<view class="page surface"><view class="tabs"><view class="tab {{filter === 'ALL' ? 'active' : ''}}" data-value="ALL" bindtap="setFilter">待处理</view><view class="tab {{filter === 'PAID' ? 'active' : ''}}" data-value="PAID" bindtap="setFilter">待发货</view><view class="tab {{filter === 'SHIPPED' ? 'active' : ''}}" data-value="SHIPPED" bindtap="setFilter">已发货</view></view><view wx:for="{{items}}" wx:key="id" class="admin-order"><view class="between"><text class="no">{{item.orderNo}}</text><order-status status="{{item.status}}" /></view><view class="meta">用户 {{item.userId}} · {{item.items.length}} 件 · {{item.createdAt}}</view><view class="between foot"><text class="price">¥{{item.totalAmount}}</text><button wx:if="{{item.status === 'PAID' || item.status === 'FULFILLING'}}" class="primary ship" data-index="{{index}}" bindtap="shipment">录入发货</button></view></view></view>
