<view class="page surface">
  <view wx:if="{{loading}}" class="loading">正在加载采购车...</view>
  <view wx:elif="{{!items.length}}" class="empty">采购车还是空的</view>
  <view wx:for="{{items}}" wx:key="productId" class="cart-row">
    <image wx:if="{{item.mainImage}}" class="thumb" src="{{item.mainImage}}" mode="aspectFill" />
    <view wx:else class="thumb placeholder">{{item.shortName}}</view>
    <view class="product-main"><view class="product-name">{{item.name}}</view><view class="meta">{{item.sku}} · ¥{{item.currentPrice}}</view>
      <view class="between cart-foot"><view class="stepper"><text data-index="{{index}}" data-delta="-1" bindtap="step">−</text><text class="value">{{item.quantity}}</text><text data-index="{{index}}" data-delta="1" bindtap="step">＋</text></view><text class="danger" data-id="{{item.productId}}" bindtap="remove">删除</text></view>
    </view>
  </view>
  <view wx:if="{{items.length}}" class="fixed-action between"><view><text class="muted">合计 </text><text class="price">¥{{total}}</text></view><button class="primary checkout" bindtap="checkout">去结算</button></view>
</view>
