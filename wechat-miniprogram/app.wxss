page {
  --green: #147451;
  --green-dark: #0b5038;
  --green-soft: #e8f3ed;
  --coral: #d9573f;
  --ink: #17231f;
  --ink-soft: #394b44;
  --muted: #74827c;
  --line: #dfe7e2;
  --canvas: #f3f6f4;
  background: var(--canvas);
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.45;
}

view, text, input, textarea, button, image, scroll-view {
  box-sizing: border-box;
}

button { margin: 0; font-size: 28rpx; border-radius: 10rpx; transition: opacity 160ms ease, transform 160ms ease, background-color 160ms ease; }
button::after { border: 0; }
button:active { opacity: .86; transform: scale(.98); }
button[disabled] { opacity: .48; }

.page { min-height: 100vh; padding: 24rpx 28rpx 176rpx; }
.surface { background: #fff; }
.section { margin-top: 24rpx; background: #fff; border: 1rpx solid var(--line); border-radius: 12rpx; }
.section-title { padding: 24rpx 0 16rpx; font-size: 32rpx; font-weight: 700; }
.section-caption { color: var(--muted); font-size: 24rpx; }
.muted { color: var(--muted); }
.price { color: var(--coral); font-size: 34rpx; font-weight: 800; font-variant-numeric: tabular-nums; }
.row { display: flex; align-items: center; min-height: 92rpx; border-bottom: 1rpx solid var(--line); }
.row:last-child { border-bottom: 0; }
.between { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; }
.primary { min-height: 88rpx; padding: 0 34rpx; background: var(--green); color: #fff; font-weight: 700; box-shadow: 0 10rpx 24rpx rgba(20, 116, 81, .16); }
.secondary { min-height: 80rpx; padding: 0 30rpx; background: #fff; color: var(--green); border: 1rpx solid var(--green); }
.danger { color: var(--coral); }
.input { min-height: 88rpx; padding: 0 24rpx; background: #fff; border: 1rpx solid var(--line); border-radius: 10rpx; }
.textarea { width: 100%; min-height: 150rpx; padding: 20rpx 22rpx; background: #fff; border: 1rpx solid var(--line); border-radius: 10rpx; }
.toolbar { position: sticky; top: 0; z-index: 5; padding: 18rpx 28rpx; margin: -24rpx -28rpx 0; background: #fff; border-bottom: 1rpx solid var(--line); }
.fixed-action { position: fixed; z-index: 10; left: 0; right: 0; bottom: 0; min-height: 116rpx; padding: 16rpx 28rpx calc(16rpx + env(safe-area-inset-bottom)); background: #fff; border-top: 1rpx solid var(--line); }
.empty { display: flex; flex-direction: column; align-items: center; padding: 112rpx 32rpx; text-align: center; color: var(--muted); background: #fff; }
.empty-mark { display: flex; align-items: center; justify-content: center; width: 104rpx; height: 104rpx; margin-bottom: 24rpx; color: var(--green); background: var(--green-soft); border-radius: 50%; font-size: 44rpx; font-weight: 700; }
.empty-title { color: var(--ink); font-size: 30rpx; font-weight: 700; }
.empty-copy { max-width: 480rpx; margin-top: 10rpx; font-size: 24rpx; line-height: 1.7; }
.empty-action { min-width: 220rpx; margin-top: 28rpx; }
.status { font-weight: 700; color: var(--green); }
.status-warn { color: var(--coral); }
.thumb { width: 164rpx; height: 164rpx; flex: 0 0 164rpx; border-radius: 10rpx; background: #edf2ef; }
.product-row { display: flex; gap: 22rpx; padding: 28rpx 0; border-bottom: 1rpx solid var(--line); }
.product-main { min-width: 0; flex: 1; }
.product-name { color: var(--ink); font-size: 31rpx; font-weight: 700; line-height: 1.45; }
.meta { margin-top: 8rpx; color: var(--muted); font-size: 24rpx; }
.stepper { display: flex; align-items: center; height: 58rpx; border: 1rpx solid var(--line); border-radius: 6rpx; overflow: hidden; }
.stepper text { width: 58rpx; text-align: center; }
.stepper .value { width: 74rpx; border-left: 1rpx solid var(--line); border-right: 1rpx solid var(--line); }
.tabs { display: flex; min-height: 76rpx; background: #fff; border-bottom: 1rpx solid var(--line); }
.tab { position: relative; flex: 1; display: flex; align-items: center; justify-content: center; color: var(--muted); }
.tab.active { color: var(--green); font-weight: 700; }
.tab.active::after { content: ''; position: absolute; left: 26%; right: 26%; bottom: 0; height: 4rpx; background: var(--green); }
.loading { padding: 70rpx; text-align: center; color: var(--muted); }
.skeleton-list { padding-top: 16rpx; }
.skeleton-row { display: flex; gap: 22rpx; padding: 28rpx 0; border-bottom: 1rpx solid var(--line); }
.skeleton-block { background: #edf2ef; border-radius: 8rpx; animation: skeleton-pulse 1.2s ease-in-out infinite alternate; }
.skeleton-image { width: 164rpx; height: 164rpx; flex: 0 0 164rpx; }
.skeleton-content { display: flex; flex: 1; flex-direction: column; gap: 18rpx; padding-top: 6rpx; }
.skeleton-line { width: 88%; height: 26rpx; }
.skeleton-line.short { width: 52%; height: 22rpx; }
.skeleton-line.price-line { width: 34%; height: 32rpx; margin-top: auto; }
@keyframes skeleton-pulse { from { opacity: .52; } to { opacity: 1; } }
